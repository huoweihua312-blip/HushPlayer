                "fixed": True,
            },
        )

        songs = liked_playlist.setdefault("songs", [])

        if not isinstance(songs, list):
            liked_playlist["songs"] = []
            songs = liked_playlist["songs"]

        return songs

    def is_song_liked(self, path: str | None) -> bool:
