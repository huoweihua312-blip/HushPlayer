            return

        self.play_queue[row + 1], self.play_queue[row] = self.play_queue[row], self.play_queue[row + 1]
        self.save_play_queue()
        self.refresh_play_queue_page()
        self.play_queue_page_list.setCurrentRow(row + 1)

